{
  "version": 1,
  "auto_continue": {
    "docs_only_changes": true,
    "approved_goal_followups": true,
    "recoverable_closeout_paths": [
      "autonomy/**",
      "docs/**",
      "README.md",
      "TEAM_GUIDE.md"
    ],
    "verification_retry": {
      "max_retry_per_task": 1,
      "allowed_failure_kinds": [
        "timeout",
        "browser_visibility",
        "cold_start",
        "transient_network"
      ]
    },
    "auto_successor_goal": {
      "enabled": true,
      "auto_approve_minimal_successor": true,
      "default_run_mode": "sprint",
      "max_consecutive_auto_successors": 3,
      "max_successor_goals_per_day": 8,
      "objective": "Keep improving the project through small, verifiable slices.",
      "success_criteria": [
        "Each successor goal remains bounded",
        "Each successor goal is verified before completion"
      ],
      "constraints": [
        "Stay inside the repository charter"
      ],
      "out_of_scope": [
        "Deployments"
      ],
      "allowed_lanes": [
        "documentation",
        "verification",
        "maintenance",
        "small_refactor"
      ],
      "forbidden_lanes": [
        "deploy",
        "release",
        "credential_change",
        "paid_external_service",
        "bulk_rewrite",
        "git_history_rewrite"
      ]
    }
  },
  "ask_human": [
    "proposal_boundary",
    "scope_change",
    "dependency_or_env",
    "security_or_secret",
    "release_or_git",
    "external_service",
    "unknown_context"
  ],
  "heartbeat": {
    "ready_next_task": "1m",
    "recoverable_or_slow_verify": "15m",
    "blocked_or_confirmation": "30m_or_pause"
  }
}
